# CORTEX-AEV environment variables
# Copy this file to `.env` and fill in real values.

# SQLite database URL used by aiosqlite (Tier-1 exact cache, Spinal Logger, etc.)
DATABASE_URL=sqlite+aiosqlite:///./data/cortex_memory.db

# Log verbosity for Spinal Logger. One of: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Anthropic API key (placeholder — replace with a real key in your local .env)
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# Filesystem path to the ChromaDB persistent store (Tier-2 semantic cache / hippocampus)
CHROMA_PATH=./data/cortex_chroma_db
